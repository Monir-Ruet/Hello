        doubleClickForFullscreen: false,      
        enableFullscreenOnRotation: false,    
        singleClickForPlayAndPause: false,    
        forceLandscapeOnFullscreen: true,
        fadeDelay: 3 
      });

      // Insert Watermark and Custom Video Scale Button
      setTimeout(() => {
        const shakaControlsContainer = container.querySelector('.shaka-controls-container');
        if (shakaControlsContainer) {
          shakaControlsContainer.appendChild(watermark);
        }

        // Custom Scale/Zoom Button logic
        const fullscreenBtn = container.querySelector('.shaka-fullscreen-button');
        if (fullscreenBtn && fullscreenBtn.parentNode) {
          const scaleBtn = document.createElement('button');
          scaleBtn.className = 'shaka-control-bar-btn mobile-scale-btn';
