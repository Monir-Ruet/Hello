      let timeLeft = 8; 

      const countdown = setInterval(() => {
        timeLeft--;
        timerText.innerText = timeLeft + "s";

        if (timeLeft <= 0) {
          clearInterval(countdown);
          startupScreen.style.opacity = "0";
          setTimeout(() => { startupScreen.style.display = "none"; }, 500);
        }
      }, 1000);
    }

