            { mode: 'cover', name: 'Screen: Zoom' },
            { mode: 'fill', name: 'Screen: Stretch' }
          ];

          scaleBtn.addEventListener('click', () => {
            currentScaleMode = (currentScaleMode + 1) % scaleModes.length;
            video.style.objectFit = scaleModes[currentScaleMode].mode;
            showToast(scaleModes[currentScaleMode].name, "success");
          });

          // Insert right before the fullscreen button
          fullscreenBtn.parentNode.insertBefore(scaleBtn, fullscreenBtn);
        }
      }, 500);

      // --- DYNAMIC RESOLUTION TEXT UPDATER ---
      function updateQualityButtonText() {
        const activeTrack = window.player.getVariantTracks().find(t => t.active);
        const qualityBtn = container.querySelector('.shaka-resolution-button');
        
        if (activeTrack && qualityBtn) {
          const height = activeTrack.height;
          if (height) {
            qualityBtn.innerHTML = `<span style="font-size: 14px; font-weight: bold; font-family: Arial, sans-serif; padding: 0 4px; display: flex; align-items: center; justify-content: center; height: 100%; color: #fff;">${height}p</span>`;
          }
        }
      }

      window.player.addEventListener('variantchanged', updateQualityButtonText);

      // --- DYNAMIC ADAPTATION (SD TO HD & SLOW NETWORK WARNING) ---
      let lastToastTime = 0;
      let currentVideoHeight = 0;

      window.player.addEventListener('adaptation', () => {
        const activeTrack = window.player.getVariantTracks().find(t => t.active);
        
        if (activeTrack) {
          const newHeight = activeTrack.height;
          const now = Date.now();

          // 1. Slow Network Warning
          if (newHeight <= 480 && currentVideoHeight > 480) {
            if (now - lastToastTime > 15000) {
              showToast("Slow connection detected. Adjusting video quality...", "error");
              lastToastTime = now;
            }
          }
          // 2. HD Upgrade Notification
          else if (newHeight >= 720 && currentVideoHeight < 720 && currentVideoHeight !== 0) {
            if (now - lastToastTime > 10000) {
              //showToast("Upgraded to HD Quality. You are now experiencing High Definition.", "success");
              lastToastTime = now;
            }
          }

          currentVideoHeight = newHeight;
        }

        updateQualityButtonText();
      });

      function showToast(msg, type) {
        const toast = document.getElementById("toast-message");
        toast.innerText = msg;
        
        if (type === "success") {
          toast.style.background = "rgba(0, 113, 235, 0.9)"; 
        } else {
          toast.style.background = "rgba(229, 9, 20, 0.9)";  
        }

        toast.style.display = 'block';
        toast.offsetHeight; 
        toast.style.opacity = '1';
        fix
        setTimeout(() => {
          toast.style.opacity = '0';
          setTimeout(() => toast.style.display = 'none', 500);
        }, 4000); 
      }

      // --- CROSS-BROWSER AUTO UNMUTE ON FULLSCREEN ---
      const handleFullscreenChange = () => {
        const isFullscreen = document.fullscreenElement || 
                             document.webkitFullscreenElement || 
                             document.mozFullScreenElement || 
                             document.msFullscreenElement;
                             
        if (isFullscreen) {
          video.muted = false; 
          video.volume = 1.0;
        }
      };
      
      document.addEventListener('fullscreenchange', handleFullscreenChange);
      document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
      document.addEventListener('mozfullscreenchange', handleFullscreenChange);
      document.addEventListener('msfullscreenchange', handleFullscreenChange);

      // --- FORCE 15s DELAY ON STARTUP ---
      let isFirstPlay = true;

      video.addEventListener('playing', () => {
        if (isFirstPlay && window.player.isLive()) {
          const seekRange = window.player.seekRange();
          if (seekRange) {
            video.currentTime = seekRange.end - 15;
            isFirstPlay = false;
          }
        }
        
        updateQualityButtonText();

        if (bufferTimeout) clearTimeout(bufferTimeout);
        loader.style.opacity = '0';
        setTimeout(() => loader.style.display = 'none', 300);
      });

      // --- DYNAMIC SYNC LOGIC ---
      setInterval(() => {
        if (video.paused || !window.player.isLive()) return;

        const seekRange = window.player.seekRange();
        if (seekRange) {
          const liveEdge = seekRange.end;
          const currentPosition = video.currentTime;
          const delay = liveEdge - currentPosition;
          
          if (delay >= 60) {
            console.warn("Stream fell behind by 60s. Auto-recovering...");
            loader.style.display = 'flex';
            loader.style.opacity = '1';
            
            video.currentTime = liveEdge - 15;
            video.playbackRate = 1.0; 
            
            setTimeout(() => { 
              loader.style.opacity = '0'; 
              setTimeout(() => loader.style.display = 'none', 300); 
            }, 800);
          }
          else if (delay > 30) {
            video.playbackRate = 1.25; 
          }
          else if (delay >= 15 && delay <= 30) {
            video.playbackRate = 1.0;
          }
          else if (delay >= 10 && delay < 15) {
            video.playbackRate = 0.95; 
          }
          else if (delay < 10) {
            video.playbackRate = 0.80; 
          }
        }
      }, 1000); 

      // --- SMART LOADER LOGIC ---
      let bufferTimeout = null;

      window.player.addEventListener('buffering', (event) => {
        if (event.buffering) {
          bufferTimeout = setTimeout(() => {
            loader.style.display = 'flex';
            loader.offsetHeight; 
            loader.style.opacity = '1';
          }, 300); 
        } else {
          if (bufferTimeout) clearTimeout(bufferTimeout);
          loader.style.opacity = '0';
          setTimeout(() => loader.style.display = 'none', 300);
        }
      });

      // Execute payload
      runEncryptedConfig();

      // Start the fake loading screen for background buffering
      //startSmartBuffering();
    }

