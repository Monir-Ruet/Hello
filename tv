  <style>
    :root { 
      --shaka-color-primary: #e50914; 
      --shaka-color-background: rgba(0, 0, 0, 0.7); 
    }
    body { 
      margin: 0; padding: 0; background-color: #000; 
      display: flex; justify-content: center; align-items: center; 
      height: 100vh; width: 100vw; overflow: hidden; font-family: Arial, sans-serif; 
    }
    .video-container { 
      width: 100%; height: 100%; position: relative; background: #000; 
      box-shadow: inset 0 0 80px rgba(0,0,0,0.9); 
    }
    video { 
      width: 100%; height: 100%; object-fit: contain; outline: none; background-color: #000; 
      touch-action: manipulation;
      transition: object-fit 0.3s ease;
    }
    video::-webkit-media-controls { 
      display: none !important; 
    }
    .shaka-spinner-container { 
      display: none !important; 
    }

    /* --- STARTUP CONNECTION SCREEN --- */
    .startup-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: #000;
      z-index: 99999;
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      color: #fff;
      font-family: Arial, sans-serif;
      text-align: center;
      transition: opacity 0.5s ease;
    }

    .startup-spinner {
      width: 40px; height: 40px;
      border: 4px solid rgba(255,255,255,0.3);
      border-top-color: #e50914;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 20px;
    }

    @keyframes spin { 
      to { transform: rotate(360deg); } 
    }

    .startup-text {
      font-size: 16px;
      line-height: 1.5;
      color: #ccc;
      padding: 0 20px;
    }

    .startup-timer {
      font-size: 24px;
      font-weight: bold;
      color: #fff;
      margin-top: 10px;
    }

    /* --- DYNAMIC TOAST NOTIFICATION --- */
    .toast-notification {
      position: absolute;
      top: 30px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(229, 9, 20, 0.85);
      color: white;
      padding: 10px 20px;
      border-radius: 25px;
      font-size: 14px;
      font-family: Arial, sans-serif;
      font-weight: bold;
      z-index: 999999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease, background 0.3s ease;
      display: none;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      text-align: center;
    }

    /* --- 3-DOT WHITE LOADER CSS --- */
    .custom-loader-wrapper { 
      position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
      background: rgba(0, 0, 0, 0.3); 
      z-index: 1000; display: none; justify-content: center; 
      align-items: center; transition: opacity 0.3s ease; opacity: 0;
    }
    .dots-container {
      display: flex;
      gap: 8px;
    }
    .dot {
      width: 14px; 
      height: 14px; 
      background-color: #ffffff; 
      border-radius: 50%; 
      animation: bounce 1.4s infinite ease-in-out both;
    }
    .dot:nth-child(1) { animation-delay: -0.32s; }
    .dot:nth-child(2) { animation-delay: -0.16s; }

    @keyframes bounce {
      0%, 80%, 100% { transform: scale(0); }
      40% { transform: scale(1); }
    }
    
    .player-watermark {
      position: absolute !important;
      bottom: 25px !important;
      right: 35px !important; 
      width: auto !important;  
      height: 20px !important;
      opacity: 0.75 !important; 
      z-index: 99999; 
      pointer-events: none !important;
      user-select: none !important;
      -webkit-user-drag: none !important;
      display: block !important;
    }

    /* --- HIDE PLAYBACK SPEED BUTTON COMPLETELY --- */
    .shaka-playback-rate-button {
      display: none !important;
    }

    /* --- DISABLE SEEKING (FORWARD/REWIND) --- */
    .shaka-seek-bar-container,
    .shaka-seek-bar {
      pointer-events: none !important;
      cursor: default !important;
    }
    .shaka-seek-bar::-webkit-slider-thumb {
      display: none !important;
      -webkit-appearance: none !important;
    }
    .shaka-seek-bar::-moz-range-thumb {
      display: none !important;
    }

    /* --- STABILIZE MUTE BUTTON & HIDE VOLUME BAR --- */
    .shaka-mute-button {
      width: 40px !important; 
      display: inline-block !important;
    }
    .shaka-volume-bar-container {
      display: none !important;
    }

    /* --- MOBILE VIDEO SCALING BUTTON (Hidden on Desktop) --- */
    .mobile-scale-btn {
      display: none !important;
      background: transparent;
      border: none;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: white;
    }
    .mobile-scale-btn svg {
      width: 24px;
      height: 24px;
      pointer-events: none;
    }

    /* --- RESPONSIVE ICONS & CONTROLS FOR MOBILE --- */
    @media screen and (max-width: 768px) {
      .startup-text {
        font-size: 14px;
        line-height: 1.6;
        padding: 0 15px;
      }
      .startup-timer {
        font-size: 22px;
      }
      .startup-spinner {
        width: 35px; height: 35px;
        margin-bottom: 15px;
      }
      .shaka-control-bar-btn {
        font-size: 24px !important; 
        margin: 0 6px !important; 
      }
      
      .toast-notification {
        width: 85%;
        font-size: 13px;
        top: 20px;
        padding: 8px 12px;
      }
      /* Show Scaling Button only on Mobile */
      .mobile-scale-btn {
        display: flex !important;
      }
    }

    @media screen and (max-width: 480px) {
      .shaka-control-bar-btn {
        font-size: 22px !important; 
        margin: 0 5px !important;
      }
      .startup-text {
        font-size: 13px;
      }
      .mobile-scale-btn svg {
        width: 22px;
        height: 22px;
      }
    }
